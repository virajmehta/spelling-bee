{
  "name": "spelling-bee",
  "version": "1.0.0",
  "description": "Spelling Bee Betting Pool Party",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply spelling-bee-db --local",
    "db:seed:local": "wrangler d1 execute spelling-bee-db --local --file=migrations/0002_seed_words.sql",
    "typecheck": "tsc --noEmit"
  },
  "packageManager": "pnpm@10.6.5",
  "dependencies": {
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260307.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
